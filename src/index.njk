    <!-- FAQ Schema -->
    <script type="application/ld+json">
    {
        "@context": "https://schema.org",
        "@type": "FAQPage",
        "mainEntity": [
            {
                "@type": "Question",
                "name": "How often should I get an eye exam?",
                "acceptedAnswer": {
                    "@type": "Answer",
                    "text": "Adults with no vision problems should get comprehensive eye exams every 2 years. If you wear glasses, have diabetes, or family history of eye disease, annual exams are recommended. Children need exams at 6 months, age 3, before school, then annually."
                }
            },
            {
                "@type": "Question",
                "name": "Do you see children? At what age?",
                "acceptedAnswer": {
                    "@type": "Answer",
                    "text": "Yes! Dr. Karimova has specialized training in pediatric ophthalmology and welcomes children from infancy through teenage years using child-friendly testing methods."
                }
            },
            {
                "@type": "Question",
                "name": "What is dry eye syndrome and how is it treated?",
                "acceptedAnswer": {
                    "@type": "Answer",
                    "text": "Dry eye syndrome causes burning, itching, redness, and watery eyes due to insufficient tear production or poor tear quality. Treatment includes prescription eye drops, punctal plugs, warm compress therapy, and lifestyle modifications. Most patients see improvement within 2-4 weeks."
                }
            },
            {
                "@type": "Question",
                "name": "How long does a comprehensive eye exam take?",
                "acceptedAnswer": {
                    "@type": "Answer",
                    "text": "A comprehensive eye examination takes approximately 45-60 minutes for your first visit. This includes visual acuity testing, refraction assessment, intraocular pressure measurement, retinal health evaluation, and consultation with Dr. Karimova."
                }
            },
            {
                "@type": "Question",
                "name": "Do you fit contact lenses?",
                "acceptedAnswer": {
                    "@type": "Answer",
                    "text": "Yes, we provide professional contact lens fitting including measurements of eye curvature and tear film quality. We offer daily disposable, monthly replacement, toric lenses for astigmatism, and multifocal lenses. Complete training and ongoing support are included."
                }
            },
            {
                "@type": "Question",
                "name": "Where is your clinic located in Dushanbe?",
                "acceptedAnswer": {
                    "@type": "Answer",
                    "text": "Our clinic is located inside Osse Optical Store at Bekhzod Street 14, Dushanbe, Tajikistan. After your appointment you can fill your prescription glasses same-day at Osse. Flexible appointment times including same-day urgent care. Contact us at +992 108 11 80 80."
                }
            }
        ]
    }
    </script>

