---
pagination:
  data: blogPages
  size: 1
  alias: item
permalink: "/{{ item.lang }}/blog/{{ item.post.slug }}/index.html"
eleventyComputed:
  title: "{{ item.post[item.lang].title }}"
---
{%- set t = locales[item.lang].strings -%}
{%- set post = item.post -%}
{%- set p = post[item.lang] -%}
{%- set lang = item.lang -%}
<!DOCTYPE html>
<html lang="{{ locales[lang].htmlLang }}">
<head>
    <!-- Google Tag Manager (idle-deferred to avoid blocking LCP/FCP) -->
    <script>
    window.dataLayer = window.dataLayer || [];
    window.dataLayer.push({'gtm.start': new Date().getTime(), event: 'gtm.js'});
    function _loadGTM() {
        var f = document.getElementsByTagName('script')[0],
            j = document.createElement('script');
        j.async = true;
        j.src = 'https://www.googletagmanager.com/gtm.js?id=GTM-TBKDQH2B';
        f.parentNode.insertBefore(j, f);
    }
    if ('requestIdleCallback' in window) {
        requestIdleCallback(_loadGTM, { timeout: 4000 });
    } else {
        setTimeout(_loadGTM, 3500);
    }
    </script>
    <!-- End Google Tag Manager -->

    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=5.0, user-scalable=yes, viewport-fit=cover">

    <title>{{ p.title }} — Dr. Sitora Karimova</title>
    <meta name="description" content="{{ p.metaDescription }}">
    <meta name="author" content="{{ post.author | default('Dr. Sitora Karimova') }}">

    <!-- Robots directives -->
    <meta name="robots" content="index, follow, max-image-preview:large">

    <!-- Canonical URL -->
    <link rel="canonical" href="https://sitorakarimi.com/{{ lang }}/blog/{{ post.slug }}/">

    <!-- Hreflang tags for this post -->
    {%- for code, loc in locales %}
    {%- if post[code] %}
    <link rel="alternate" hreflang="{{ loc.hreflang }}" href="https://sitorakarimi.com/{{ code }}/blog/{{ post.slug }}/">
    {%- endif %}
    {%- endfor %}
    <link rel="alternate" hreflang="x-default" href="https://sitorakarimi.com/ru/blog/{{ post.slug }}/">

    <!-- Open Graph -->
    <meta property="og:type" content="article">
    <meta property="og:url" content="https://sitorakarimi.com/{{ lang }}/blog/{{ post.slug }}/">
    <meta property="og:site_name" content="Dr. Sitora Karimova Ophthalmology">
    <meta property="og:title" content="{{ p.title }}">
    <meta property="og:description" content="{{ p.metaDescription }}">
    <meta property="og:locale" content="{{ locales[lang].htmlLang }}">
    {%- if post.image %}
    <meta property="og:image" content="https://sitorakarimi.com{{ post.image }}">
    {%- endif %}
    <meta property="article:published_time" content="{{ post.date }}">
    <meta property="article:author" content="{{ post.author | default('Dr. Sitora Karimova') }}">
    {%- if post.category %}
    <meta property="article:section" content="{{ post.category }}">
    {%- endif %}
    {%- for tag in post.tags %}
    <meta property="article:tag" content="{{ tag }}">
    {%- endfor %}

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="{{ p.title }}">
    <meta name="twitter:description" content="{{ p.metaDescription }}">
    {%- if post.image %}
    <meta name="twitter:image" content="https://sitorakarimi.com{{ post.image }}">
    {%- endif %}

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg">

    <!-- Fonts (non-render-blocking) -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="preload" href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" as="style" onload="this.onload=null;this.rel='stylesheet'">
    <noscript><link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet"></noscript>

    <!-- Tailwind CSS (pre-built) -->
    <link rel="stylesheet" href="/tailwind.css?v=1.3.1">

    <!-- Font Awesome (non-render-blocking) -->
    <link rel="preload" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" as="style" onload="this.onload=null;this.rel='stylesheet'" integrity="sha512-iecdLmaskl7CVkqkXNQ/ZH/XLlvWZOJyj7Yy7tcenmpD1ypASozpmT/E0iPtmFIB46ZmdtAc9eNBvH0H/ZpiBw==" crossorigin="anonymous">
    <noscript><link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" integrity="sha512-iecdLmaskl7CVkqkXNQ/ZH/XLlvWZOJyj7Yy7tcenmpD1ypASozpmT/E0iPtmFIB46ZmdtAc9eNBvH0H/ZpiBw==" crossorigin="anonymous"></noscript>

    <!-- Styles -->
    <link rel="stylesheet" href="/styles.css">
    <link rel="stylesheet" href="/blog/blog.css">

    <!-- Structured Data: Article -->
    <script type="application/ld+json">
    {
        "@context": "https://schema.org",
        "@type": "Article",
        "headline": "{{ p.title }}",
        "description": "{{ p.metaDescription }}",
        "datePublished": "{{ post.date }}",
        "url": "https://sitorakarimi.com/{{ lang }}/blog/{{ post.slug }}/",
        "inLanguage": "{{ locales[lang].htmlLang }}",
        {%- if post.image %}
        "image": "https://sitorakarimi.com{{ post.image }}",
        {%- endif %}
        "author": {
            "@type": "Person",
            "name": "{{ post.author | default('Dr. Sitora Karimova') }}",
            "jobTitle": "Ophthalmologist",
            "url": "https://sitorakarimi.com/{{ lang }}/"
        },
        "publisher": {
            "@type": "Organization",
            "name": "Dr. Sitora Karimova Ophthalmology",
            "url": "https://sitorakarimi.com"
        },
        "mainEntityOfPage": {
            "@type": "WebPage",
            "@id": "https://sitorakarimi.com/{{ lang }}/blog/{{ post.slug }}/"
        }
    }
    </script>
</head>
<body class="font-poppins font-light text-gray-700 bg-white" data-lang="{{ lang }}">
    <!-- Google Tag Manager (noscript) -->
    <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-TBKDQH2B"
    height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>

    <!-- AI Translation Banner -->
    {%- if post.aiTranslated and lang in post.aiTranslated %}
    <div class="ai-translation-banner">
        <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 flex items-center justify-center gap-2">
            <i class="fas fa-language text-sm"></i>
            <span>{{ t.blog.aiTranslatedBanner | safe }}</span>
            {%- if post.en %}
            <a href="/en/blog/{{ post.slug }}/" class="underline hover:no-underline ml-1">{{ t.blog.viewOriginal | safe }}</a>
            {%- endif %}
        </div>
    </div>
    {%- endif %}

    <!-- Navigation -->
    <nav class="fixed top-0 w-full bg-navy-900 z-50 transition-all shadow-lg" id="navbar">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex justify-between items-center h-20">
                <a href="/{{ lang }}/" class="flex items-center space-x-2 hover:opacity-90 transition-opacity">
                    <div class="w-10 h-10 bg-white rounded-full flex items-center justify-center">
                        <i class="fas fa-eye text-navy-900 text-xl"></i>
                    </div>
                    <span class="font-semibold text-lg text-white">Dr. Sitora Karimova</span>
                </a>
                <div class="hidden lg:flex items-center space-x-8">
                    <a href="/{{ lang }}/" class="nav-link-light">{{ t.nav.home | safe }}</a>
                    <a href="/{{ lang }}/#services" class="nav-link-light">{{ t.nav.services | safe }}</a>
                    <a href="/{{ lang }}/#about" class="nav-link-light">{{ t.nav.about | safe }}</a>
                    <a href="/{{ lang }}/blog/" class="nav-link-light active">{{ t.nav.blog | safe }}</a>
                    <a href="/{{ lang }}/#contact" class="nav-link-light">{{ t.nav.contact | safe }}</a>

                    <!-- Language Switcher -->
                    <div class="relative language-switcher">
                        <button id="lang-btn" class="flex items-center space-x-2 text-white hover:text-coral transition-colors" aria-label="Language selector" aria-haspopup="true" aria-expanded="false">
                            <i class="fas fa-globe text-lg" aria-hidden="true"></i>
                            <span id="current-lang" class="text-sm font-medium">{{ lang | upper }}</span>
                            <i class="fas fa-chevron-down text-xs" aria-hidden="true"></i>
                        </button>
                        <div id="lang-menu" class="hidden absolute right-0 mt-2 w-32 bg-white rounded-lg shadow-xl overflow-hidden z-50" role="menu">
                            {%- for code, loc in locales %}
                            {%- if post[code] %}
                            <a href="/{{ code }}/blog/{{ post.slug }}/" class="lang-option block w-full text-left px-4 py-2 text-sm text-gray-700 hover:bg-coral hover:text-white transition-colors" role="menuitem">{{ loc.name }}</a>
                            {%- endif %}
                            {%- endfor %}
                        </div>
                    </div>
                </div>
                <button class="lg:hidden text-white" id="mobile-menu-btn" aria-label="Toggle mobile menu" aria-expanded="false">
                    <i class="fas fa-bars text-2xl" aria-hidden="true"></i>
                </button>
            </div>
        </div>
        <!-- Mobile Menu -->
        <div id="mobile-menu" class="hidden lg:hidden bg-navy-900 border-t border-white/10">
            <div class="px-4 py-3 space-y-3">
                <a href="/{{ lang }}/" class="block nav-link-light">{{ t.nav.home | safe }}</a>
                <a href="/{{ lang }}/#services" class="block nav-link-light">{{ t.nav.services | safe }}</a>
                <a href="/{{ lang }}/#about" class="block nav-link-light">{{ t.nav.about | safe }}</a>
                <a href="/{{ lang }}/blog/" class="block nav-link-light active">{{ t.nav.blog | safe }}</a>
                <a href="/{{ lang }}/#contact" class="block nav-link-light">{{ t.nav.contact | safe }}</a>

                <!-- Mobile Language Switcher -->
                <div class="pt-3 border-t border-white/10">
                    <p class="text-xs uppercase tracking-widest text-white/60 mb-2">{{ t.nav.language | safe }}</p>
                    <div class="flex gap-2">
                        {%- for code, loc in locales %}
                        {%- if post[code] %}
                        <a href="/{{ code }}/blog/{{ post.slug }}/" class="lang-option-mobile flex-1 px-3 py-2 text-sm text-white bg-white/10 rounded hover:bg-coral transition-colors text-center">{{ code | upper }}</a>
                        {%- endif %}
                        {%- endfor %}
                    </div>
                </div>
            </div>
        </div>
    </nav>

    <!-- Article -->
    <article class="blog-post">
        <!-- Post Header -->
        <header class="pt-32 pb-12 bg-gradient-to-b from-navy-900 to-navy-800">
            <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
                <!-- Breadcrumb -->
                <nav class="mb-6" aria-label="Breadcrumb">
                    <ol class="flex items-center space-x-2 text-sm text-white/50">
                        <li><a href="/{{ lang }}/" class="hover:text-white transition-colors">{{ t.nav.home | safe }}</a></li>
                        <li><i class="fas fa-chevron-right text-[10px]"></i></li>
                        <li><a href="/{{ lang }}/blog/" class="hover:text-white transition-colors">{{ t.nav.blog | safe }}</a></li>
                        <li><i class="fas fa-chevron-right text-[10px]"></i></li>
                        <li class="text-white/80 truncate max-w-[200px]">{{ p.title | safe }}</li>
                    </ol>
                </nav>

                {%- if post.category %}
                <span class="inline-block text-xs uppercase tracking-widest font-medium text-coral mb-3">{{ t.blog.categories[post.category] | default(post.category) | safe }}</span>
                {%- endif %}

                <h1 class="text-3xl md:text-4xl lg:text-5xl font-semibold text-white mb-6 leading-tight">{{ p.title | safe }}</h1>

                <div class="flex flex-wrap items-center gap-4 text-sm text-white/60">
                    {%- if post.author %}
                    <span class="flex items-center gap-2">
                        <i class="fas fa-user-md"></i> {{ post.author }}
                    </span>
                    {%- endif %}
                    <span class="flex items-center gap-2">
                        <i class="far fa-calendar"></i> {{ post.date }}
                    </span>
                    {%- if post.readingTime %}
                    <span class="flex items-center gap-2">
                        <i class="far fa-clock"></i> {{ post.readingTime }} {{ t.blog.minRead | safe }}
                    </span>
                    {%- endif %}
                </div>
            </div>
        </header>

        {%- if post.image %}
        <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 -mt-6">
            <div class="rounded-lg overflow-hidden shadow-lg">
                <img src="{{ post.image }}" alt="{{ p.title }}" class="w-full h-auto"
                     onerror="this.parentElement.style.display='none'">
            </div>
        </div>
        {%- endif %}

        <!-- Post Content -->
        <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
            <div class="blog-content prose prose-lg max-w-none" id="blog-content">
                {{ p.content | safe }}
            </div>

            {%- if post.source and post.source.name %}
            <div class="mt-12 pt-6 border-t border-gray-200">
                <p class="text-sm text-gray-400">
                    {{ t.blog.sourceLabel | safe }}: <em>{{ post.source.name }}</em>
                    {%- if post.source.date %} ({{ post.source.date }}){%- endif %}
                </p>
            </div>
            {%- endif %}

            {%- if post.tags and post.tags.length %}
            <div class="mt-8 flex flex-wrap gap-2">
                {%- for tag in post.tags %}
                <span class="blog-tag">#{{ tag }}</span>
                {%- endfor %}
            </div>
            {%- endif %}

            <!-- Share & Back -->
            <div class="mt-12 pt-8 border-t border-gray-200 flex flex-wrap items-center justify-between gap-4">
                <a href="/{{ lang }}/blog/" class="inline-flex items-center text-sm font-medium text-navy-900 hover:text-coral transition-colors">
                    <i class="fas fa-arrow-left mr-2"></i> {{ t.blog.backToBlog | safe }}
                </a>
                <div class="flex items-center gap-3">
                    <span class="text-sm text-gray-400">{{ t.blog.share | safe }}:</span>
                    <button onclick="shareTo('twitter')" class="blog-share-btn" aria-label="Share on Twitter">
                        <i class="fab fa-twitter"></i>
                    </button>
                    <button onclick="shareTo('facebook')" class="blog-share-btn" aria-label="Share on Facebook">
                        <i class="fab fa-facebook-f"></i>
                    </button>
                    <button onclick="shareTo('telegram')" class="blog-share-btn" aria-label="Share on Telegram">
                        <i class="fab fa-telegram-plane"></i>
                    </button>
                    <button onclick="copyLink()" class="blog-share-btn" aria-label="Copy link" id="copy-link-btn">
                        <i class="fas fa-link"></i>
                    </button>
                </div>
            </div>
        </div>
    </article>

    <!-- Footer -->
    <footer class="bg-gray-50 text-gray-600 py-16 border-t border-gray-200">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="grid md:grid-cols-4 gap-12 mb-12">
                <div>
                    <h4 class="font-medium text-navy-900 mb-4">Sitora Karimova</h4>
                    <p class="text-sm font-light">{{ t.footer.tagline | safe }}</p>
                </div>
                <div>
                    <h4 class="font-medium text-navy-900 mb-4">{{ t.footer.servicesTitle | safe }}</h4>
                    <ul class="space-y-2 text-sm font-light">
                        <li><a href="/{{ lang }}/#services" class="hover:text-coral transition-colors">{{ t.footer.eyeExams | safe }}</a></li>
                        <li><a href="/{{ lang }}/#services" class="hover:text-coral transition-colors">{{ t.footer.glasses | safe }}</a></li>
                        <li><a href="/{{ lang }}/#services" class="hover:text-coral transition-colors">{{ t.footer.contacts | safe }}</a></li>
                    </ul>
                </div>
                <div>
                    <h4 class="font-medium text-navy-900 mb-4">{{ t.footer.infoTitle | safe }}</h4>
                    <ul class="space-y-2 text-sm font-light">
                        <li><a href="/{{ lang }}/#about" class="hover:text-coral transition-colors">{{ t.footer.about | safe }}</a></li>
                        <li><a href="/{{ lang }}/blog/" class="hover:text-coral transition-colors">{{ t.nav.blog | safe }}</a></li>
                        <li><a href="/{{ lang }}/#contact" class="hover:text-coral transition-colors">{{ t.footer.contact | safe }}</a></li>
                    </ul>
                </div>
                <div>
                    <h4 class="font-medium text-navy-900 mb-4">{{ t.footer.connect | safe }}</h4>
                    <div class="flex space-x-4">
                        <a href="#" class="text-gray-400 hover:text-coral transition-colors"><i class="fab fa-facebook text-xl"></i></a>
                        <a href="#" class="text-gray-400 hover:text-coral transition-colors"><i class="fab fa-instagram text-xl"></i></a>
                    </div>
                </div>
            </div>
            <div class="border-t border-gray-200 pt-8">
                <p class="text-sm text-center font-light">{{ t.footer.copyright | safe }}</p>
            </div>
        </div>
    </footer>

    <!-- JavaScript -->
    <script>window.__T__ = {{ t | dump | safe }}; window.__LANG__ = "{{ lang }}";</script>
    <script src="/blog/blog.js"></script>
</body>
</html>
