<!DOCTYPE html>
<html lang="{{ locales[lang].htmlLang }}">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ locales[lang].strings.meta.title }}</title>
  <meta name="description" content="{{ locales[lang].strings.meta.description }}">

  <link rel="canonical" href="https://sitorakarimi.com/{{ lang }}/">
  {%- for code, loc in locales %}
  <link rel="alternate" hreflang="{{ loc.hreflang }}" href="https://sitorakarimi.com/{{ code }}/">
  {%- endfor %}
  <link rel="alternate" hreflang="x-default" href="https://sitorakarimi.com/ru/">

  <meta property="og:locale" content="{{ locales[lang].htmlLang }}">
  <meta property="og:title" content="{{ locales[lang].strings.meta.ogTitle or locales[lang].strings.meta.title }}">
  <meta property="og:description" content="{{ locales[lang].strings.meta.description }}">
  <meta property="og:url" content="https://sitorakarimi.com/{{ lang }}/">
  <meta property="og:type" content="website">

  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
  <link rel="stylesheet" href="/styles.css">
</head>
<body data-lang="{{ lang }}">
  <nav class="lang-switcher" aria-label="Language">
    {%- for code, loc in locales %}
      <a href="/{{ code }}/" hreflang="{{ loc.hreflang }}"{% if code == lang %} aria-current="page"{% endif %}>{{ loc.name }}</a>
    {%- endfor %}
  </nav>

  {{ content | safe }}

  <script src="/script.js"></script>
  <script src="/vision-test.js"></script>
  <script src="/vision-disorders.js"></script>
</body>
</html>
