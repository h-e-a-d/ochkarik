{
  "name": "sitorakarimi-site",
  "version": "1.0.0",
  "private": true,
  "description": "Multilingual ophthalmology website for Dr. Sitora Karimova (RU/TJ/EN)",
  "scripts": {
    "dev": "tailwindcss -i ./tailwind.input.css -o ./tailwind.css --watch & eleventy --serve --quiet",
    "build": "tailwindcss -i ./tailwind.input.css -o ./tailwind.css --minify && eleventy",
    "clean": "rm -rf _site tailwind.css"
  },
  "devDependencies": {
    "@11ty/eleventy": "^3.0.0",
    "tailwindcss": "^3.4.19"
  }
}
